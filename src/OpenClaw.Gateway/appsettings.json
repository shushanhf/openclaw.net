    "Memory": {
      "Provider": "file",
      "StoragePath": "./memory",
      "MaxHistoryTurns": 50,
      "MaxCachedSessions": null,
      "Sqlite": {
        "DbPath": "./memory/openclaw.db",
        "EnableFts": true,
        "EnableVectors": false
      },
      "Recall": {
        "Enabled": false,
        "MaxNotes": 8,
        "MaxChars": 8000
      },
      "Retention": {
        "Enabled": false,
        "RunOnStartup": true,
        "SweepIntervalMinutes": 30,
        "SessionTtlDays": 30,
        "BranchTtlDays": 14,
        "ArchiveEnabled": true,
        "ArchivePath": "./memory/archive",
        "ArchiveRetentionDays": 30,
        "MaxItemsPerSweep": 1000
      }
    },
    "Security": {
      "AllowQueryStringToken": false,
      "AllowedOrigins": [],
      "TrustForwardedHeaders": false,
      "KnownProxies": [],
      "RequireRequesterMatchForHttpToolApproval": false,
      "AllowUnsafeToolingOnPublicBind": false,
      "AllowPluginBridgeOnPublicBind": false,
      "AllowRawSecretRefsOnPublicBind": false
    },
    "WebSocket": {
      "MaxMessageBytes": 1048576,
      "MaxConnections": 1000,
      "MaxConnectionsPerIp": 50,
      "MessagesPerMinutePerConnection": 120,
      "ReceiveTimeoutSeconds": 120
    },
    "Tooling": {
      "AutonomyMode": "supervised",
      "WorkspaceRoot": "env:OPENCLAW_WORKSPACE",
      "WorkspaceOnly": false,
      "AllowedShellCommandGlobs": [ "*" ],
      "ForbiddenPathGlobs": [],
      "AllowShell": true,
      "ReadOnlyMode": false,
      "AllowedReadRoots": [
        "*"
      ],
      "AllowedWriteRoots": [
        "*"
      ],
      "AllowBrowserEvaluate": true,
      "ToolApprovalTimeoutSeconds": 300
