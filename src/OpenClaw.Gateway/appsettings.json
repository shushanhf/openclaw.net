    "DynamicTurnRouting": {
      "Enabled": false,
      "BundlePath": "models/routing/opensquilla-v4-compat",
      "Policy": {
        "EnableStickyTier": true,
        "EnableMarginUpgrade": true,
        "EnableUnderRoutingSafety": true,
        "Tiers": {
          "T0": {
            "ModelProfileId": "deepseek-v4-flash",
            "PreferredTags": [
              "cheap",
              "latency-low"
            ],
            "DisableTools": true,
            "PromptMode": "minimal"
          },
          "T1": {
            "ModelProfileId": "glm-4-7",
            "PreferredTags": [
              "cost-balanced",
              "t1"
            ],
            "AllowedTools": [
              "read_file",
              "grep_search",
              "get_errors"
            ],
            "PromptMode": "compact"
          },
          "T2": {
            "ModelProfileId": "deepseek-v4-pro",
            "PreferredTags": [
              "balanced",
              "tool-reliable",
              "t2"
            ]
          },
          "T3": {
            "ModelProfileId": "openai",
            "PreferredTags": [
              "frontier",
              "reasoning-heavy",
              "t3"
            ]
          }
        }
      }
