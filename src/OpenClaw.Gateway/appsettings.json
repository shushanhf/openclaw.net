    "ExternalCli": {
      "Enabled": false,
      "DefaultTimeoutSeconds": 60,
      "MaxStdoutBytes": 262144,
      "MaxStderrBytes": 65536,
      "RedactSecrets": true,
      "AllowFreeformCommands": false,
      "RequireApprovalForMutatingCommands": true,
      "Presets": [],
      "Connectors": {}
    },
    "Sandbox": {
      "Provider": "None"
    },
